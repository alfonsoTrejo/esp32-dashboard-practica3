{
  "name": "esp32-dashboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n NEXT,WS -c blue,magenta \"npm run dev:next\" \"npm run dev:ws\"",
    "dev:next": "next dev",
    "dev:ws": "tsx watch app/server/websocket-server.ts",
    "build": "next build",
    "start": "concurrently -n NEXT,WS -c blue,magenta \"npm run start:next\" \"npm run start:ws\"",
    "start:next": "next start",
    "start:ws": "tsx app/server/websocket-server.ts"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "concurrently": "^9.2.1",
    "lucide-react": "^0.544.0",
    "next": "16.0.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "tailwind-merge": "^3.3.1",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@types/ws": "^8.18.1",
    "tailwindcss": "^4.1.12",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}